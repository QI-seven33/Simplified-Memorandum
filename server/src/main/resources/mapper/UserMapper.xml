<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.media.server.mapper.UserMapper">

    <!-- 注册：插入新用户 -->
    <insert id="register" parameterType="com.media.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username,email,password,role,status,created_at
        ) VALUES (#{username},#{email},#{password},#{role},#{status},#{createdAt})
    </insert>
    <!-- ========== 新增：更新用户信息 ========== -->
    <update id="updateUserInfo">
        UPDATE user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="bio != null">
                bio = #{bio},
            </if>
            <if test="avatar != null">
                avatar = #{avatar},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    <select id="getInformation" resultType="com.media.entity.User">
        SELECT id, username, avatar, bio, password
        FROM user
        WHERE id = #{id}
          AND status = 'active'
    </select>

</mapper>